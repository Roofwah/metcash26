PORT=5001
CORS_ORIGIN=*

# ── Supabase / PostgreSQL connection ──────────────────────────────────────────
# Get this from Supabase → Settings → Database → Connection string → URI
# Make sure to replace [YOUR-PASSWORD] with the actual database password.
#
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.fducsqpnpxlkgejcihsi.supabase.co:5432/postgres




# Set DB_SSL=false ONLY if connecting to a local, unencrypted Postgres instance.
# Leave as-is (or omit) for Supabase — SSL is required.
DB_SSL=true

# ── Authentication (magic-link) ───────────────────────────────────────────────
# Comma-separated allowed rep emails. If empty, all emails are allowed.
ALLOWED_LOGIN_EMAILS=
AUTH_SESSION_DAYS=10
MAGIC_LINK_MINUTES=15
APP_BASE_URL=http://localhost:5001

# ── SMTP email delivery ────────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=
AUTH_EMAIL_FROM=
ORDER_EMAIL_FROM=
ORDER_REPLY_TO=

