PORT=5001
CORS_ORIGIN=*

# ── Supabase / PostgreSQL connection ──────────────────────────────────────────
# Get this from Supabase → Settings → Database → Connection string → URI
# Make sure to replace [YOUR-PASSWORD] with the actual database password.
#
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.fducsqpnpxlkgejcihsi.supabase.co:5432/postgres




# Set DB_SSL=false ONLY if connecting to a local, unencrypted Postgres instance.
# Leave as-is (or omit) for Supabase — SSL is required.
DB_SSL=true

# ── Authentication (OTP code) ────────────────────────────────────────────────
# Comma-separated allowed rep emails. If empty, all emails are allowed.
ALLOWED_LOGIN_EMAILS=
AUTH_SESSION_DAYS=10
# Optional for cross-host persistence (e.g. dble.co + www.dble.co): .dble.co
AUTH_SESSION_COOKIE_DOMAIN=
OTP_CODE_MINUTES=15
OTP_MAX_ATTEMPTS=5
# Local testing helper: when true (and not production), request-link can return localOtpCode.
ALLOW_LOCAL_OTP_PREVIEW=false
APP_BASE_URL=http://localhost:5001
# Optional: force a public logo URL in auth emails (recommended for local testing)
AUTH_EMAIL_LOGO_URL=https://dble.co/metcash26/dble_logo.svg

# ── SMTP email delivery ────────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=
AUTH_EMAIL_FROM=
ORDER_EMAIL_FROM=
ORDER_REPLY_TO=

